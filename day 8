  class Solution {
    public int gcdOfOddEvenSums(int n) {
        return gcd(n*(n+1),n*n);
    }
    public static int gcd(int a,int b){
        if(b==0)return a;
        return gcd(b,a%b);
    }
}
2.
  CREATE FUNCTION getNthHighestSalary(N INT) RETURNS INT
BEGIN
    -- Convert N to zero-based indexing for OFFSET
    SET N = N - 1;

    -- Return the Nth highest unique salary
    RETURN (
        -- Select unique salaries and sort them in descending order
        SELECT DISTINCT salary
        FROM Employee
        ORDER BY salary DESC

        -- Skip the first N salaries and return the next one
        LIMIT 1 OFFSET N
    );
END
