  class MyLinkedList {
    // Blueprint for individual nodes 🧱
    class Node {
        int val;
        Node next;

        Node(int val) {
            this.val = val;
            this.next = null;
        }
    }
    
    Node head;
    Node tail;
    int NON; // Number Of Nodes

    public MyLinkedList() {
        head = null;
        tail = null;
        NON = 0;
    }
    
    public int get(int index) {
        // Index out of bounds check
        if(index < 0 || index >= NON || head == null) {
            return -1;
        } else {
            Node temp = head;
            for(int i = 0; i < index; i++) {
                temp = temp.next;
            }
            return temp.val;
        }
    }
    
    public void addAtHead(int val) {
        Node newNode = new Node(val);
        if(head == null) {
            head = tail = newNode;
        } else {
            newNode.next = head;
            head = newNode;
        }
        NON++;            
    }
    
    public void addAtTail(int val) {
        Node newNode = new Node(val);
        if(tail == null) {
            head = tail = newNode;
        } else {
            tail.next = newNode;
            tail = newNode;
        }
        NON++;
    }
    
    public void addAtIndex(int index, int val) {
        if(index < 0 || index > NON) {
            return;
        }
        if(index == 0) {
            addAtHead(val);
        } else if(index == NON) {
            addAtTail(val);
        } else {
            Node newNode = new Node(val);
            Node temp = head;
            // Stop at the node right before the insertion index 🛠️
            for(int i = 0; i < index - 1; i++) {
                temp = temp.next;
            }
            newNode.next = temp.next;
            temp.next = newNode;
            NON++;
        }
    }
    
    public void deleteAtIndex(int index) {
        if(index < 0 || index >= NON || head == null) {
            return;
        } else if(head == tail) { // Single node deletion 🛑
            head = null;
            tail = null;
            NON--;
        } else if(index == 0) { // Delete head ↙️
            head = head.next;
            NON--;
        } else if(index == NON - 1) { // Delete tail ↘️
            Node temp = head;
            while(temp.next != tail) {
                temp = temp.next;
            }
            temp.next = null;
            tail = temp;
            NON--;
        } else { // Delete from middle ✂️
            Node temp = head;
            for(int i = 0; i < index - 1; i++) {
                temp = temp.next;
            }
            temp.next = temp.next.next;
            NON--;
        }
    }
}
